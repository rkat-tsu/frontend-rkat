				{
					"name": "500/Conflict Delete (Foreign Key)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 302/500/409\", function () {",
									"    // Karena di controller ada try-catch yang redirect back with error,",
									"    // biasanya akan return 302 Found (Redirect) atau 200 (Inertia Error Bag).",
									"    // Jika kita paksa JSON header, mungkin 500.",
									"    pm.expect(pm.response.code).to.be.oneOf([302, 500, 200]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
